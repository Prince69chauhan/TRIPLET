# ============================================================
#  Triplet — PRODUCTION environment template
#  1. Copy to .env on the deployment VM:  cp .env.production.example .env
#  2. Replace every CHANGE_ME with a real value
#  3. Point DOMAIN's DNS A record at the VM's public IP BEFORE first start
#     (otherwise Let's Encrypt cert issuance will fail)
#  NEVER commit the resulting .env to git.
# ============================================================

# ── Domain & HTTPS ──────────────────────────────────────────
# Your apex or subdomain (no scheme, no trailing slash). Caddy will request a
# Let's Encrypt cert for exactly this name on first start.
DOMAIN=CHANGE_ME_your-domain.com

# Email Let's Encrypt uses to notify you about expiry issues.
ACME_EMAIL=CHANGE_ME_you@example.com

# Public URL — derived from DOMAIN, used by frontend + backend CORS.
PUBLIC_HOST=https://${DOMAIN}

# ── Database (generate a strong password: openssl rand -base64 24) ──
POSTGRES_USER=triplet_user
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=triplet
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://triplet_user:CHANGE_ME_DB_PASSWORD@db:5432/triplet
SYNC_DATABASE_URL=postgresql://triplet_user:CHANGE_ME_DB_PASSWORD@db:5432/triplet

# ── Redis (openssl rand -base64 24) ──────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0

# ── MinIO (openssl rand -base64 24) ──────────────────────────
MINIO_ROOT_USER=triplet_minio_admin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=resumes
MINIO_SECURE=false

# ── JWT (openssl rand -hex 32) ───────────────────────────────
SECRET_KEY=CHANGE_ME_64_CHAR_HEX
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── RSA keys (auto-generated by deploy/oracle-setup.sh on first run) ──
RSA_PRIVATE_KEY_PATH=/app/keys/private_key.pem
RSA_PUBLIC_KEY_PATH=/app/keys/public_key.pem

# ── Email (Gmail App Password recommended; leave placeholders if no email yet) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME_EMAIL
SMTP_PASSWORD=CHANGE_ME_APP_PASSWORD
EMAIL_FROM=CHANGE_ME_EMAIL
EMAIL_FROM_NAME=Triplet

# ── SBERT model ──────────────────────────────────────────────
SBERT_MODEL=all-MiniLM-L6-v2
SBERT_MODEL_VERSION=sbert-v1

# ── Celery ───────────────────────────────────────────────────
CELERY_BROKER_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/1
INTEGRITY_CHECK_INTERVAL_HOURS=6

# ── Frontend build arg (same as PUBLIC_HOST above) ───────────
NEXT_PUBLIC_API_URL=${PUBLIC_HOST}

# ── App ──────────────────────────────────────────────────────
APP_NAME=Triplet
APP_ENV=production
DEBUG=false
ALLOWED_ORIGINS=${PUBLIC_HOST}
