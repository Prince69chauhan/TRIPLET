# ============================================================
#  Triplet — Environment Variables Template
#  Copy this file to .env and fill in your values
#  This file IS safe to commit to git (.env is NOT)
# ============================================================

POSTGRES_USER=triplet_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=triplet
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://triplet_user:CHANGE_ME@db:5432/triplet
SYNC_DATABASE_URL=postgresql://triplet_user:CHANGE_ME@db:5432/triplet

REDIS_PASSWORD=CHANGE_ME
REDIS_URL=redis://:CHANGE_ME@redis:6379/0

MINIO_ROOT_USER=triplet_minio_admin
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=resumes
MINIO_SECURE=false

SECRET_KEY=CHANGE_ME_64_CHAR_HEX
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

RSA_PRIVATE_KEY_PATH=/app/keys/private_key.pem
RSA_PUBLIC_KEY_PATH=/app/keys/public_key.pem

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
EMAIL_FROM=CHANGE_ME
EMAIL_FROM_NAME=Triplet

SBERT_MODEL=all-MiniLM-L6-v2
SBERT_MODEL_VERSION=sbert-v1

CELERY_BROKER_URL=redis://:CHANGE_ME@redis:6379/0
CELERY_RESULT_BACKEND=redis://:CHANGE_ME@redis:6379/1
INTEGRITY_CHECK_INTERVAL_HOURS=6

NEXT_PUBLIC_API_URL=http://localhost:8000

APP_NAME=Triplet
APP_ENV=development
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000
